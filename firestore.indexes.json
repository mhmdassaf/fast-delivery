{
  "indexes": [
    // Orders indexes
    {
      "collectionGroup": "orders",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "userId", "order": "ascending" },
        { "fieldPath": "createdAt", "order": "descending" }
      ]
    },
    {
      "collectionGroup": "orders",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "riderId", "order": "ascending" },
        { "fieldPath": "status", "order": "ascending" }
      ]
    },
    {
      "collectionGroup": "orders",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "sellerId", "order": "ascending" },
        { "fieldPath": "createdAt", "order": "descending" }
      ]
    },
    {
      "collectionGroup": "orders",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "status", "order": "ascending" },
        { "fieldPath": "createdAt", "order": "descending" }
      ]
    },
    
    // Items indexes
    {
      "collectionGroup": "items",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "sellerId", "order": "ascending" },
        { "fieldPath": "category", "order": "ascending" }
      ]
    },
    {
      "collectionGroup": "items",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "sellerId", "order": "ascending" },
        { "fieldPath": "isAvailable", "order": "ascending" }
      ]
    },
    
    // Reviews indexes
    {
      "collectionGroup": "reviews",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "sellerId", "order": "ascending" },
        { "fieldPath": "createdAt", "order": "descending" }
      ]
    },
    {
      "collectionGroup": "reviews",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "itemId", "order": "ascending" },
        { "fieldPath": "createdAt", "order": "descending" }
      ]
    },
    
    // Menu Items indexes (subcollection: shops/{shopId}/menu_items)
    {
      "collectionGroup": "menu_items",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "isActive", "order": "ascending" },
        { "fieldPath": "order", "order": "ascending" }
      ]
    },

    // Chats indexes
    {
      "collectionGroup": "chats",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "participantIds", "arrayConfig": "CONTAINS" },
        { "fieldPath": "lastMessageAt", "order": "descending" }
      ]
    },
    
    // Notifications indexes
    {
      "collectionGroup": "notifications",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "userId", "order": "ascending" },
        { "fieldPath": "createdAt", "order": "descending" }
      ]
    },
    {
      "collectionGroup": "notifications",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "userId", "order": "ascending" },
        { "fieldPath": "isRead", "order": "ascending" }
      ]
    },
    
    // --- Dashboard Feature Indexes ---
    
    // Categories: isActive + order (display order)
    {
      "collectionGroup": "categories",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "isActive", "order": "ascending" },
        { "fieldPath": "order", "order": "ascending" }
      ]
    },
    
    // Shops: isActive + createdAt (base query, no filters)
    {
      "collectionGroup": "shops",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "isActive", "order": "ascending" },
        { "fieldPath": "createdAt", "order": "descending" }
      ]
    },
    
    // Shops: isActive + categoryId + createdAt (category filter)
    {
      "collectionGroup": "shops",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "isActive", "order": "ascending" },
        { "fieldPath": "categoryId", "order": "ascending" },
        { "fieldPath": "createdAt", "order": "descending" }
      ]
    },
    
    // Shops: isActive + isOpen + createdAt (open now filter)
    {
      "collectionGroup": "shops",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "isActive", "order": "ascending" },
        { "fieldPath": "isOpen", "order": "ascending" },
        { "fieldPath": "createdAt", "order": "descending" }
      ]
    },
    
    // Shops: isActive + categoryId + isOpen + createdAt (category + open now)
    {
      "collectionGroup": "shops",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "isActive", "order": "ascending" },
        { "fieldPath": "categoryId", "order": "ascending" },
        { "fieldPath": "isOpen", "order": "ascending" },
        { "fieldPath": "createdAt", "order": "descending" }
      ]
    }
  ],
  "fieldOverrides": [
    {
      "collectionGroup": "users",
      "fieldPath": "fcmTokens",
      "indexes": [
        { "order": "CONTAINS" }
      ]
    }
  ]
}
