rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // =========================================================================
    // HELPER FUNCTIONS
    // =========================================================================
    
    /// Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    /// Check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    /// Get user document data
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    /// Check if user has a specific role
    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }
    
    /// Check if user is admin
    function isAdmin() {
      return hasRole('admin');
    }
    
    /// Check if user is active
    function isUserActive() {
      return isAuthenticated() && getUserData().isActive == true;
    }
    
    // =========================================================================
    // USERS COLLECTION
    // =========================================================================
    match /users/{userId} {
      /// Anyone authenticated can read user profiles
      allow read: if isAuthenticated();
      
      /// Users can only read their own full profile, admins can read all
      allow get: if isOwner(userId) || isAdmin();
      
      /// Users can only create their own document
      allow create: if isOwner(userId) && 
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.role == 'user' &&
        request.resource.data.keys().hasAll(['uid', 'email', 'role', 'createdAt']);
      
      /// Users can only update their own profile (specific fields)
      allow update: if isOwner(userId) && 
        request.resource.data.keys().hasAll([
          'displayName', 'phoneNumber', 'updatedAt'
        ]);
      
      /// Users can update their own FCM tokens
      allow update: if isOwner(userId) && 
        request.resource.data.keys().hasOnly(['fcmTokens', 'updatedAt']);
      
      /// Only admins can update roles and admin fields
      allow update: if isAdmin() && 
        request.resource.data.keys().hasAny(['role', 'isActive']);
      
      /// Only admins can delete users
      allow delete: if isAdmin();
    }
    
    // =========================================================================
    // USER ADDRESSES (subcollection)
    // =========================================================================
    match /users/{userId}/addresses/{addressId} {
      allow read, write: if isOwner(userId);
    }
    
    // =========================================================================
    // RIDERS COLLECTION
    // =========================================================================
    match /riders/{riderId} {
      /// Authenticated users can read rider profiles (for order display)
      allow read: if isAuthenticated();
      
      /// Riders can only read their own profile
      allow get: if hasRole('rider') && request.auth.uid == riderId;
      
      /// Riders can create their own profile
      allow create: if hasRole('rider') && 
        request.auth.uid == riderId &&
        request.resource.data.uid == request.auth.uid;
      
      /// Riders can update their own profile
      allow update: if hasRole('rider') && request.auth.uid == riderId;
      
      /// Admins can manage all rider profiles
      allow read, write: if isAdmin();
    }
    
    // =========================================================================
    // SELLERS COLLECTION
    // =========================================================================
    match /sellers/{sellerId} {
      /// Authenticated users can read seller profiles (for browsing restaurants)
      allow read: if isAuthenticated();
      
      /// Sellers can only read their own profile
      allow get: if hasRole('seller') && request.auth.uid == sellerId;
      
      /// Sellers can create their own profile
      allow create: if hasRole('seller') && 
        request.auth.uid == sellerId &&
        request.resource.data.uid == request.auth.uid;
      
      /// Sellers can update their own profile
      allow update: if hasRole('seller') && request.auth.uid == sellerId;
      
      /// Admins can manage all seller profiles
      allow read, write: if isAdmin();
    }
    
    // =========================================================================
    // ORDERS COLLECTION
    // =========================================================================
    match /orders/{orderId} {
      /// Users can read their own orders
      allow read: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
      
      /// Riders can read orders assigned to them
      allow read: if hasRole('rider') && 
        resource.data.riderId == request.auth.uid;
      
      /// Sellers can read their orders
      allow read: if hasRole('seller') && 
        resource.data.sellerId == request.auth.uid;
      
      /// Admins can read all orders
      allow read: if isAdmin();
      
      /// Users can create orders
      allow create: if hasRole('user') && 
        request.resource.data.userId == request.auth.uid;
      
      /// Riders can update assigned orders (status changes)
      allow update: if hasRole('rider') && 
        request.auth.uid == resource.data.riderId &&
        request.resource.data.keys().hasAny(['status', 'updatedAt']);
      
      /// Sellers can update order status
      allow update: if hasRole('seller') && 
        request.auth.uid == resource.data.sellerId &&
        request.resource.data.keys().hasAny(['status', 'updatedAt']);
      
      /// Admins can update any order
      allow update: if isAdmin();
      
      /// Users can cancel their own pending orders
      allow update: if hasRole('user') && 
        isOwner(resource.data.userId) && 
        resource.data.status == 'pending' &&
        request.resource.data.status == 'cancelled';
      
      /// No one can delete orders (keep history)
      allow delete: if false;
    }
    
    // =========================================================================
    // ITEMS COLLECTION (Menu Items)
    // =========================================================================
    match /items/{itemId} {
      /// Anyone authenticated can read menu items
      allow read: if isAuthenticated();
      
      /// Sellers can manage their own items
      allow create, update: if hasRole('seller') && 
        request.auth.uid == resource.data.sellerId;
      
      /// Sellers can delete their own items
      allow delete: if hasRole('seller') && 
        request.auth.uid == resource.data.sellerId;
      
      /// Admins can manage all items
      allow read, write: if isAdmin();
    }
    
    // =========================================================================
    // NOTIFICATIONS COLLECTION
    // =========================================================================
    match /notifications/{notifId} {
      /// Users can only read their own notifications
      allow read: if isOwner(resource.data.userId);
      
      /// Users can mark notifications as read
      allow update: if isOwner(resource.data.userId) && 
        request.resource.data.keys().hasOnly(['isRead', 'updatedAt']);
      
      /// System can create notifications (via Cloud Functions)
      allow create: if isAdmin();
      
      /// Users can delete their own read notifications
      allow delete: if isOwner(resource.data.userId) && 
        resource.data.isRead == true;
    }
    
    // =========================================================================
    // CHATS COLLECTION
    // =========================================================================
    match /chats/{chatId} {
      /// Participants can read the chat
      allow read: if isAuthenticated() && 
        request.auth.uid in resource.data.participantIds;
      
      /// Participants can send messages
      allow create: if isAuthenticated() && 
        request.auth.uid in request.resource.data.participantIds;
      
      /// Participants can update the chat
      allow update: if isAuthenticated() && 
        request.auth.uid in resource.data.participantIds;
      
      /// Admins can access all chats
      allow read, write: if isAdmin();
    }
    
    // =========================================================================
    // REVIEWS COLLECTION
    // =========================================================================
    match /reviews/{reviewId} {
      /// Anyone authenticated can read reviews
      allow read: if isAuthenticated();
      
      /// Users can create reviews for completed orders
      allow create: if hasRole('user') && 
        request.resource.data.userId == request.auth.uid;
      
      /// Users can update their own reviews
      allow update: if isOwner(resource.data.userId);
      
      /// Users can delete their own reviews
      allow delete: if isOwner(resource.data.userId);
      
      /// Admins can manage all reviews
      allow read, write: if isAdmin();
    }
  }
}