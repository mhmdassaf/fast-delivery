rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return request.auth.uid == uid;
    }
    
    // User profile images
    match /users/{userId}/profile/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) && 
        request.resource.size < 5 * 1024 * 1024 && // Max 5MB
        request.resource.contentType.matches('image/.*');
    }
    
    // Rider documents
    match /riders/{riderId}/documents/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isOwner(riderId) &&
        request.resource.size < 10 * 1024 * 1024 && // Max 10MB
        request.resource.contentType.matches('application/pdf|image/.*');
    }
    
    // Seller/restaurant images
    match /sellers/{sellerId}/{fileName} {
      allow read: if isAuthenticated();
      allow write: if isOwner(sellerId) &&
        request.resource.size < 5 * 1024 * 1024 && // Max 5MB
        request.resource.contentType.matches('image/.*');
    }
    
    // Order item images
    match /items/{itemId}/{fileName} {
      allow read: if isAuthenticated();
      allow write: if request.auth != null && // Seller check would be done in Firestore
        request.resource.size < 2 * 1024 * 1024 && // Max 2MB
        request.resource.contentType.matches('image/.*');
    }
    
    // Chat attachments
    match /chats/{chatId}/attachments/{fileName} {
      allow read: if isAuthenticated();
      allow write: if request.auth != null &&
        request.resource.size < 10 * 1024 * 1024 && // Max 10MB
        request.resource.contentType.matches('application/pdf|image/.*');
    }
  }
}